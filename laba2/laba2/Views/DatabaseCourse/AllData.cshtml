@model List<laba2.Models.DatabaseCourseModel>

@{
    ViewData["Title"] = "Просмотр всех музеев";
    var i = 0;
}

<h1>Просмотр всех музеев</h1>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(m => m[0].Id)</th>
            <th>@Html.DisplayNameFor(m => m[0].Name)</th>
            <th>@Html.DisplayNameFor(m => m[0].Curator)</th>
            <th>@Html.DisplayNameFor(m => m[0].CollectionSize)</th>
            <th>@Html.DisplayNameFor(m => m[0].Established)</th>
            <th>@Html.DisplayNameFor(m => m[0].TicketPrice)</th>
            <th>@Html.DisplayNameFor(m => m[0].IsGuidedToursAvailable)</th>
            <th>@Html.DisplayNameFor(m => m[0].OpeningHours)</th>
        </tr>
    </thead>
    <tbody>
        @while (i < Model.Count)
        {
            <tr>
                <td>@Html.DisplayFor(m => m[i].Id)</td>
                <td>@Html.DisplayFor(m => m[i].Name)</td>
                <td>@Html.DisplayFor(m => m[i].Curator)</td>
                <td>@Html.DisplayFor(m => m[i].CollectionSize)</td>
                <td>@Html.DisplayFor(m => m[i].Established)</td>
                <td>@Html.DisplayFor(m => m[i].TicketPrice)</td>
                <td>@Html.DisplayFor(m => m[i].IsGuidedToursAvailable)</td>
                <td>@Html.DisplayFor(m => m[i].OpeningHours)</td>
            </tr>
            i++;
        }
    </tbody>
</table>

<p>
    <a asp-action="Index" class="btn btn-secondary">Назад к списку</a>
</p>
